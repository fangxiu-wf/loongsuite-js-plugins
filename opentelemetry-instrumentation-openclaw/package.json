{
  "name": "@loongsuite/opentelemetry-instrumentation-openclaw",
  "version": "0.1.2",
  "description": "OpenTelemetry instrumentation for OpenClaw — report AI agent execution traces to any OTLP-compatible backend",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alibaba/loongsuite-js-plugins.git",
    "directory": "opentelemetry-instrumentation-openclaw"
  },
  "homepage": "https://github.com/alibaba/loongsuite-js-plugins/tree/main/opentelemetry-instrumentation-openclaw#readme",
  "bugs": {
    "url": "https://github.com/alibaba/loongsuite-js-plugins/issues"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "openclaw",
    "ai-agent",
    "llm",
    "observability",
    "tracing",
    "instrumentation",
    "loongsuite"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "bin": {
    "openclaw-cms-plugin-onboard-cli": "./dist/onboard-cli.js",
    "openclaw-otel-plugin-onboard-cli": "./dist/onboard-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@loongsuite/opentelemetry-util-genai": "^0.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "commander": "^14.0.3",
    "inquirer": "^13.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "^5.0.0",
    "vitest": "^4.1.3"
  }
}
