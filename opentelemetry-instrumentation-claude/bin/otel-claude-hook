"use strict";

/**
 * otel-claude-hook — CLI entry point.
 *
 * Usage:
 *   otel-claude-hook user-prompt-submit  (stdin: JSON from Claude hook)
 *   otel-claude-hook pre-tool-use
 *   otel-claude-hook post-tool-use
 *   otel-claude-hook stop
 *   otel-claude-hook pre-compact
 *   otel-claude-hook subagent-start
 *   otel-claude-hook subagent-stop
 *   otel-claude-hook notification
 *   otel-claude-hook install [--user] [--project]
 *   otel-claude-hook show-config
 *   otel-claude-hook check-env
 */

const { Command } = require("commander");
const {
  cmdUserPromptSubmit,
  cmdPreToolUse,
  cmdPostToolUse,
  cmdPreCompact,
  cmdSubagentStart,
  cmdSubagentStop,
  cmdNotification,
  cmdStop,
  cmdInstall,
  cmdUninstall,
  cmdShowConfig,
  cmdCheckEnv,
} = require("../src/cli");

const program = new Command();

program
  .name("otel-claude-hook")
  .description("Claude Code settings.json hook commands for OpenTelemetry tracing")
  .version(require("../package.json").version);

program
  .command("user-prompt-submit")
  .description("Handle UserPromptSubmit hook — initialize session state")
  .action(() => { cmdUserPromptSubmit(); });

program
  .command("pre-tool-use")
  .description("Handle PreToolUse hook — record tool-start event")
  .action(() => { cmdPreToolUse(); });

program
  .command("post-tool-use")
  .description("Handle PostToolUse hook — record tool-completion event")
  .action(() => { cmdPostToolUse(); });

program
  .command("pre-compact")
  .description("Handle PreCompact hook — record context-compaction event")
  .action(() => { cmdPreCompact(); });

program
  .command("subagent-start")
  .description("Handle SubagentStart hook — record subagent launch")
  .action(() => { cmdSubagentStart(); });

program
  .command("subagent-stop")
  .description("Handle SubagentStop hook — record subagent completion (with child state snapshot)")
  .action(() => { cmdSubagentStop(); });

program
  .command("notification")
  .description("Handle Notification hook — record notification event")
  .action(() => { cmdNotification(); });

program
  .command("stop")
  .description("Handle Stop hook — export complete OTel trace for this session")
  .action(async () => {
    try {
      await cmdStop();
    } catch (err) {
      // Telemetry failures must NOT block the agent — exit 0 after warning.
      console.error("[otel-claude-hook] stop failed (telemetry error, agent unaffected):", err?.message || String(err));
    }
  });

program
  .command("install")
  .description("Add otel-claude-hook hooks to .claude/settings.json")
  .option("--user", "Install into user-level settings (~/.claude/settings.json)", true)
  .option("--no-user", "Skip user-level settings")
  .option("--project", "Install into project-level settings (.claude/settings.json)")
  .option("--quiet", "Silent mode: warn on error instead of exiting (for postinstall use)")
  .action(async (opts) => {
    try {
      await cmdInstall(opts);
    } catch (err) {
      console.error("[otel-claude-hook] install failed:", err?.message || String(err));
      process.exit(1);
    }
  });

program
  .command("uninstall")
  .description("Remove hooks, intercept.js, and the claude shell alias")
  .option("--user", "Remove from user-level settings (~/.claude/settings.json)", true)
  .option("--no-user", "Skip user-level settings")
  .option("--project", "Remove from project-level settings (.claude/settings.json)")
  .option("--purge", "Also delete the entire cache directory (including session data)")
  .action((opts) => { cmdUninstall(opts); });

program
  .command("show-config")
  .description("Print the JSON snippet to add to .claude/settings.json")
  .action(() => { cmdShowConfig(); });

program
  .command("check-env")
  .description("Check that a telemetry backend is configured and print its status")
  .action(() => { cmdCheckEnv(); });

program.parseAsync(process.argv).catch((err) => {
  console.error("[otel-claude-hook] error:", err?.message || String(err));
  process.exit(1);
});
